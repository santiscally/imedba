<mxfile host="app.diagrams.net">
  <diagram id="ERD-IMEDBA-v2" name="Entidad-Relación Simplificado">
    <mxGraphModel dx="2200" dy="1600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="3000" pageHeight="2000" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ========== ACADÉMICO + FACTURACIÓN (Azul/Verde) ========== -->
