        <mxCell id="enrollments" value="enrollments&#xa;────────────────────────&#xa;PK id: UUID&#xa;FK student_id, course_id&#xa;FK discount_campaign_id&#xa;enrolled_by (Keycloak UUID)&#xa;list_price, discount_pct&#xa;final_price, book_price, total_price&#xa;enrollment_fee, num_installments&#xa;payment_method (ENUM)&#xa;contract_file_path, contract_sent_at&#xa;status (ENUM), moodle_status&#xa;notes, created_at, deleted_at" style="shape=table;startSize=25;container=0;fontStyle=1;align=left;overflow=auto;html=0;fontSize=11;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
