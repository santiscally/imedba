          <mxGeometry x="40" y="20" width="1100" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="students" value="students&#xa;────────────────&#xa;PK id: UUID&#xa;first_name, last_name&#xa;email (UNIQUE), phone&#xa;dni, nationality&#xa;university, locality&#xa;is_active, moodle_user_id&#xa;notes&#xa;created_at, deleted_at" style="shape=table;startSize=25;container=0;fontStyle=1;align=left;overflow=auto;html=0;fontSize=11;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
