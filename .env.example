# -----------------------------------------------------------------------------
# Copiar a `.env` y ajustar. NO commitear `.env`.
# -----------------------------------------------------------------------------

# --- Postgres (una sola instancia, aloja DB imedba + DB keycloak) ------------
POSTGRES_DB=imedba
POSTGRES_USER=imedba
POSTGRES_PASSWORD=imedba_dev_change_me
POSTGRES_PORT=5432

# --- Keycloak ----------------------------------------------------------------
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin_dev_change_me
KEYCLOAK_PORT=8081
KEYCLOAK_HOSTNAME=localhost
# URLs usadas por el backend. En dev apuntan al contenedor por red interna.
# En prod:
#   KEYCLOAK_ISSUER_URI  = https://${SERVER_NAME}/auth/realms/imedba     (publico, match del iss del JWT)
#   KEYCLOAK_JWK_SET_URI = http://keycloak:8080/auth/realms/imedba/protocol/openid-connect/certs  (interno)
KEYCLOAK_ISSUER_URI=http://keycloak:8080/realms/imedba
KEYCLOAK_JWK_SET_URI=http://keycloak:8080/realms/imedba/protocol/openid-connect/certs

# Secret del client confidential imedba-backend. Regenerarlo en la consola
# Keycloak despues de importar el realm y pegarlo aca.
IMEDBA_BACKEND_CLIENT_SECRET=replace-me-after-realm-import

# --- Backend -----------------------------------------------------------------
SPRING_PROFILES_ACTIVE=dev
BACKEND_PORT=8080
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Frontend (Vite) ---------------------------------------------------------
FRONTEND_PORT=5173
# Vars inyectadas al build del SPA. En dev el browser habla directo contra los
# puertos expuestos; en prod el override usa "/api" y "/auth" (mismo origen).
VITE_API_BASE_URL=http://localhost:8080
VITE_KEYCLOAK_URL=http://localhost:8081
VITE_KEYCLOAK_REALM=imedba
VITE_KEYCLOAK_CLIENT_ID=imedba-frontend

# --- Nginx (prod) ------------------------------------------------------------
# Dominio publico del sitio. Debe matchear el CN/SAN del certificado TLS.
SERVER_NAME=imedba.local

# --- SendGrid ----------------------------------------------------------------
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=no-reply@imedba.local
SENDGRID_FROM_NAME=IMEDBA

# --- Misc --------------------------------------------------------------------
TZ=America/Argentina/Buenos_Aires
